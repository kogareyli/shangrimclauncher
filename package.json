{
  "name": "shangrimc-launcher",
  "version": "1.0.0",
  "description": "ShangriMc Official Launcher — Forge 1.20.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.shangrimc.launcher",
    "productName": "ShangriMc Launcher",
    "publish": {
      "provider": "github",
      "owner": "eddyzaz38",
      "repo": "shangrimclauncher",
      "private": false
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShangriMc Launcher"
    },
    "files": [
      "**/*",
      "mods/**",
      "!node_modules/.cache",
      "!.git"
    ],
    "extraResources": [
      {
        "from": "forge-1.20.1-47.4.18-installer.jar",
        "to": "forge-1.20.1-47.4.18-installer.jar"
      }
    ]
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.16.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "adm-zip": "^0.5.10"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}
