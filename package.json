{
  "name": "shangrimc-launcher",
  "version": "1.1.0",
  "description": "ShangriMc Official Launcher â€” Forge 1.20.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.shangrimc.launcher",
    "productName": "ShangriMc Launcher",
    "copyright": "Copyright Â© 2025 ShangriMc",
    "publish": {
      "provider": "github",
      "owner": "kogareyli",
      "repo": "shangrimclauncher",
      "private": false
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "artifactName": "ShangriMc-Launcher-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShangriMc Launcher",
      "language": "1036"
    },
    "files": [
      "**/*",
      "assets/**",
      "src/**",
      "!node_modules/.cache",
      "!.git",
      "!dist",
      "!*.bat",
      "!build",
      "!forge-*.jar"
    ],
    "extraResources": [
      { "from": "forge-1.20.1-47.4.18-installer.jar", "to": "forge-1.20.1-47.4.18-installer.jar" },
      { "from": "assets/icon.ico", "to": "assets/icon.ico" }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "minecraft-launcher-core": "^3.16.3",
    "msmc": "^4.1.2",
    "node-fetch": "^2.7.0",
    "prismarine-auth": "^2.5.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}